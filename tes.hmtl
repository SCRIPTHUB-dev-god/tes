<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link to Binary & Lua Generator</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            background: white;
            width: 100%;
            max-width: 720px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            text-align: center;
            padding: 32px 20px;
        }

        h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
        }

        p {
            margin: 8px 0 0;
            opacity: 0.9;
            font-size: 16px;
        }

        .content {
            padding: 40px 35px;
        }

        .input-group {
            position: relative;
            margin-bottom: 25px;
        }

        input {
            width: 100%;
            padding: 16px 20px;
            font-size: 17px;
            border: 2px solid #e0e7ff;
            border-radius: 12px;
            outline: none;
            transition: all 0.3s;
            box-sizing: border-box;
        }

        input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        }

        button.convert-btn {
            width: 100%;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            border: none;
            padding: 16px;
            font-size: 17px;
            font-weight: 600;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 30px;
        }

        button.convert-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }

        .result-container {
            display: none;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .result {
            background: #f8fafc;
            border-radius: 16px;
            padding: 25px;
            border: 1px solid #e0e7ff;
        }

        .label {
            font-size: 14px;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        pre {
            background: #1e2937;
            color: #bae6fd;
            padding: 20px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.6;
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-all;
            max-height: 250px;
            margin: 0;
            font-family: 'Courier New', Courier, monospace;
        }

        .copy-btn {
            margin-top: 15px;
            background: #64748b;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
        }

        .copy-btn.roblox {
            background: #0ea5e9;
        }

        .copy-btn:hover {
            filter: brightness(0.9);
        }

        .footer {
            text-align: center;
            padding: 20px;
            color: #94a3b8;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🔗 Link to Binary</h1>
            <p>Ubah link menjadi kode biner & Script Loader Roblox</p>
        </header>

        <div class="content">
            <div class="input-group">
                <input type="text" id="linkInput" placeholder="https://example.com/script.lua" autocomplete="off">
            </div>

            <button class="convert-btn" onclick="convertToBinary()">🔄 Ubah ke Biner</button>

            <div id="resultsWrapper" style="display: none;">
                <div class="result" style="margin-bottom: 20px;">
                    <div class="label">Binary Result (Paling Padat)</div>
                    <pre id="binaryOutput"></pre>
                    <button class="copy-btn" onclick="copyText('binaryOutput', this)">📋 Copy Binary</button>
                </div>

                <div class="result">
                    <div class="label">Roblox Studio Loadstring Script</div>
                    <pre id="luaOutput"></pre>
                    <button class="copy-btn roblox" onclick="copyText('luaOutput', this)">🎮 Copy Roblox Script</button>
                </div>
            </div>
        </div>

        <div class="footer">
            Link to Binary Converter • Clean & Fast
        </div>
    </div>

    <script>
        function convertToBinary() {
            const input = document.getElementById('linkInput').value.trim();
            const resultsWrapper = document.getElementById('resultsWrapper');

            if (!input) {
                alert("❌ Silakan masukkan link terlebih dahulu!");
                return;
            }

            // 1. Konversi ke binary
            const encoder = new TextEncoder();
            const bytes = encoder.encode(input);
            let binary = '';

            for (let byte of bytes) {
                binary += byte.toString(2).padStart(8, '0');
            }

            // 2. Buat Script Lua untuk Roblox
            const luaScript = `local biner = "${binary}"

local function decodeBinary(binStr)
    local text = ""
    -- Membaca setiap 8 karakter (1 byte) dari string biner
    for i = 1, #binStr, 8 do
        local byteStr = string.sub(binStr, i, i+7)
        local char = string.char(tonumber(byteStr, 2))
        text = text .. char
    end
    return text
end

local normalLink = decodeBinary(biner)
loadstring(game:HttpGet(normalLink))()`;

            // Tampilkan hasil
            document.getElementById('binaryOutput').textContent = binary;
            document.getElementById('luaOutput').textContent = luaScript;
            resultsWrapper.style.display = 'block';
        }

        function copyText(elementId, btnElement) {
            const textToCopy = document.getElementById(elementId).textContent;
            const originalText = btnElement.innerHTML;
            const originalBg = window.getComputedStyle(btnElement).backgroundColor;
            
            navigator.clipboard.writeText(textToCopy).then(() => {
                btnElement.innerHTML = '✅ Berhasil Dicopy!';
                btnElement.style.background = '#10b981'; // Warna hijau sukses
                
                setTimeout(() => {
                    btnElement.innerHTML = originalText;
                    btnElement.style.background = originalBg;
                }, 2000);
            });
        }

        // Tekan Enter untuk konversi
        document.getElementById('linkInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                convertToBinary();
            }
        });
    </script>
</body>
</html>
